# Trial Weave — local config
# Copy this file to .env and fill in values from your Supabase project's
# API settings (https://supabase.com/dashboard/project/<id>/settings/api).
#
# Both values are PUBLIC by Supabase's design — RLS policies, not key
# obscurity, are what protect data. .env is gitignored anyway.

SUPABASE_URL=
SUPABASE_ANON_KEY=
