# ==============================================================================
# .gitignore — Flutter (iOS + Android + Web + macOS/Windows/Linux)
# Production-ready. Heavily annotated so you know WHY each line exists.
#
# Philosophy:
#   - Commit source, configs, lockfiles.
#   - Ignore build artifacts, caches, IDE user-specific files, secrets, keys,
#     and anything generated by the toolchain at build time.
#   - Generated Dart files (*.g.dart, *.freezed.dart) are COMMITTED here.
#     If your team prefers to regenerate them in CI, move that block to the
#     "Codegen" section below and uncomment.
# ==============================================================================

# ------------------------------------------------------------------------------
# OS / filesystem junk
# ------------------------------------------------------------------------------
.DS_Store              # macOS Finder metadata
.DS_Store?
._*                    # macOS resource forks
.Spotlight-V100
.Trashes
ehthumbs.db            # Windows thumbnail cache
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*~                     # Linux backup files
.nfs*                  # NFS temp files

# ------------------------------------------------------------------------------
# Editors / IDEs — user-specific, never commit
# ------------------------------------------------------------------------------

# IntelliJ / Android Studio
*.iml
*.ipr
*.iws
.idea/
# Exception: you CAN commit run configs if the team shares them:
# !.idea/runConfigurations/

# VS Code
.vscode/
# Teams sometimes commit a shared subset — uncomment if you want that:
# !.vscode/settings.json
# !.vscode/launch.json
# !.vscode/extensions.json
# !.vscode/tasks.json

# Cursor / Zed / Fleet / Sublime / Vim / Emacs
.cursor/
.zed/
.fleet/
*.sublime-workspace
*.sublime-project
*.swp
*.swo
*~
.\#*                   # emacs lock files
\#*\#

# Xcode user-specific (see iOS section for more)
xcuserdata/

# ------------------------------------------------------------------------------
# Dart / Flutter — core build artifacts
# ------------------------------------------------------------------------------
.dart_tool/            # Pub cache per-project; regenerated by `pub get`
.flutter-plugins       # Generated plugin list (regenerated on build)
.flutter-plugins-dependencies
.packages              # Legacy package-config; still appears sometimes
.pub-cache/            # In case pub cache lands in the project
.pub/
build/                 # All compiled output — never commit
/build/                # Root-level build dir (some tools write here)

# ------------------------------------------------------------------------------
# FVM (Flutter Version Management) — pin the version, ignore the SDK copy
# ------------------------------------------------------------------------------
# COMMIT:
#   .fvmrc             ← your project's pinned Flutter version
#   .fvm/fvm_config.json (legacy, if present)

# ------------------------------------------------------------------------------
# Coverage output — regenerate per run
# ------------------------------------------------------------------------------
coverage/
*.lcov

# ------------------------------------------------------------------------------
# Codegen — freezed, json_serializable, riverpod_generator, drift, retrofit
# ------------------------------------------------------------------------------
# DEFAULT (this file): COMMIT generated files. Easier for small teams, no
# "run build_runner first" surprise for new clones, CI stays simple.
#
# If you prefer to NOT commit them (bigger teams, cleaner diffs), uncomment:
# *.g.dart
# *.freezed.dart
# *.gr.dart            # auto_route
# *.mocks.dart         # mockito
# *.config.dart        # injectable
# *.drift.dart         # drift legacy
# lib/**/*.g.dart
# lib/**/*.freezed.dart
# ...and add this step to CI:
#   dart run build_runner build --delete-conflicting-outputs

# Always ignore these regardless — they're build-process only:
.generated/

# ------------------------------------------------------------------------------
# Secrets, env, config — NEVER commit
# ------------------------------------------------------------------------------
.env
.env.*
!.env.example          # Safe example template — DO commit
!.env.sample
secrets/
*.pem
*.key                  # ⚠️ ignores ALL .key files — careful if you have other uses
*.p12                  # Certs (iOS push, Apple dev certs)
*.p8                   # App Store Connect API key
*.mobileprovision      # iOS provisioning profiles
*.cer                  # Apple certs
*.certSigningRequest
credentials.json
service-account*.json
gha-creds-*.json       # google-auth GHA action

# ------------------------------------------------------------------------------
# iOS
# ------------------------------------------------------------------------------

# CocoaPods — vendored dependencies; regenerate with `pod install`
ios/Pods/
ios/.symlinks/

# Flutter-generated iOS files (regenerated on build)
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/app.flx
ios/Flutter/app.zip
ios/Flutter/flutter_assets/
ios/Flutter/flutter_export_environment.sh
ios/ServiceDefinitions.json
ios/Runner/GeneratedPluginRegistrant.*

# Xcode build output / user state
ios/build/
ios/DerivedData/
ios/**/xcuserdata/
ios/**/xcuserdatad/
ios/**/*.xcworkspace/xcuserdata/
ios/**/*.xcodeproj/xcuserdata/
ios/**/*.xcodeproj/project.xcworkspace/xcuserdata/
ios/**/*.xcodeproj/project.xcworkspace/xcshareddata/WorkspaceSettings.xcsettings
ios/**/*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/

# Xcode workspace junk
**/*.mode1v3
**/*.mode2v3
**/*.perspectivev3
**/*.pbxuser
**/*.moved-aside
**/DerivedData/
**/*.hmap
**/*.ipa
**/*.dSYM.zip
**/*.dSYM

# Firebase (iOS) — plist per flavor, generated by `flutterfire configure`
# If you commit these, Firebase project IDs leak in git history.
ios/Runner/GoogleService-Info.plist
ios/Runner/**/GoogleService-Info.plist
# If you have per-flavor plists, they live outside git too:
ios/config/dev/GoogleService-Info.plist
ios/config/staging/GoogleService-Info.plist
ios/config/prod/GoogleService-Info.plist

# Fastlane (iOS) — ignore reports + generated screenshots; commit Fastfile/Appfile
ios/fastlane/report.xml
ios/fastlane/Preview.html
ios/fastlane/screenshots/
ios/fastlane/test_output/
ios/fastlane/README.md
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/
fastlane/test_output/

# ------------------------------------------------------------------------------
# Android
# ------------------------------------------------------------------------------

# Gradle caches / local state
android/.gradle/
android/captures/
android/.idea/
android/**/build/

# Local developer-machine config (SDK paths, etc.) — machine-specific
android/local.properties

# Generated Java/Kotlin plugin registrants
android/**/GeneratedPluginRegistrant.java
android/**/GeneratedPluginRegistrant.kt

# Key files — signing assets NEVER go in git
android/key.properties
android/app/key.properties
*.jks
*.keystore
# Keep debug keystore if your team uses a shared one:
# !android/app/debug.keystore

# Firebase (Android) — flavored google-services.json
android/app/google-services.json
android/app/src/dev/google-services.json
android/app/src/staging/google-services.json
android/app/src/prod/google-services.json

# NDK / obfuscation artifacts
android/app/release/
android/app/debug/
android/app/profile/

# ------------------------------------------------------------------------------
# Web (when you add it)
# ------------------------------------------------------------------------------
web/index.html.tmpl    # Generated if you use templated index
# Firebase Hosting
.firebase/
.firebaserc            # OPTIONAL: contains project IDs; some commit, some don't
firebase-debug.log
firebase-debug.*.log

# ------------------------------------------------------------------------------
# Desktop targets (macOS / Windows / Linux) — only ignore if you build them
# ------------------------------------------------------------------------------
macos/Flutter/ephemeral/
macos/Pods/
macos/**/xcuserdata/
macos/**/*.xcworkspace/xcuserdata/
macos/**/*.xcodeproj/xcuserdata/

windows/flutter/ephemeral/
windows/flutter/generated_plugin_registrant.cc
windows/flutter/generated_plugin_registrant.h
windows/flutter/generated_plugins.cmake

linux/flutter/ephemeral/
linux/flutter/generated_plugin_registrant.cc
linux/flutter/generated_plugin_registrant.h
linux/flutter/generated_plugins.cmake

# ------------------------------------------------------------------------------
# Release binaries / exports — build output, never source
# ------------------------------------------------------------------------------
*.apk
*.aab
*.app
*.ipa
*.xcarchive
*.dmg
*.pkg
*.exe
*.msi

# ------------------------------------------------------------------------------
# Logs, tmp, crashes
# ------------------------------------------------------------------------------
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tmp
*.temp
*.bak
*.orig
*.rej
crash-*.log
hs_err_pid*.log        # JVM crash logs

# ------------------------------------------------------------------------------
# Node (if using any JS tooling — e.g. Firebase Functions, web assets)
# ------------------------------------------------------------------------------
node_modules/
.npm/
.yarn/
.pnp.*

# ------------------------------------------------------------------------------
# Python (if tooling or scripts use it)
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ------------------------------------------------------------------------------
# Misc tooling
# ------------------------------------------------------------------------------
.direnv/               # direnv
.envrc.local
.netrc
.history/              # VS Code local history extension
.turbo/                # if you use Turborepo / mono-repo tooling
.nx/
melos_*.iml            # Melos (Flutter monorepo tool)
pubspec_overrides.yaml # Melos override — team decision; often gitignored

# ==============================================================================
# What you SHOULD commit (reminders — NOT patterns):
# ==============================================================================
#
#   pubspec.yaml
#   pubspec.lock            ← apps commit; packages/libs exclude
#   analysis_options.yaml
#   .fvmrc                  ← pins Flutter SDK version
#   .github/                ← workflows, templates, CODEOWNERS, dependabot.yml
#   .githooks/              ← shared git hooks
#   .env.example            ← template for local .env
#   README.md, LICENSE, CHANGELOG.md
#   ios/Podfile             ← commit the declaration, not Pods/
#   ios/Podfile.lock        ← commit for reproducible CocoaPods installs
#   android/build.gradle, app/build.gradle
#   android/gradle/wrapper/gradle-wrapper.properties
#   android/gradle/wrapper/gradle-wrapper.jar
#   Runner.xcodeproj (minus xcuserdata)
#   Fastfile, Appfile, Matchfile  ← Fastlane configs; just not screenshots/reports
#
# ==============================================================================

# FVM Version Cache
.fvm/